{
  "name": "cocos-knowledge-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync": "node scripts/sync-content.mjs",
    "build": "node scripts/build.mjs",
    "release": "npm run sync && npm run build",
    "preview": "npm run build && http-server dist -p 4173 -c-1",
    "deploy:preview": "npx vercel",
    "deploy:prod": "npx vercel --prod",
    "clean": "node -e \"import('node:fs').then(({rmSync}) => rmSync('dist', { recursive: true, force: true }))\""
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "http-server": "^14.1.1"
  }
}
